PORT=4100
NODE_ENV=production
# Puedes poner varios separados por coma
CORS_ORIGIN=https://matudb.com,https://www.matudb.com,https://matucash.web.app,https://matucash.firebaseapp.com,http://localhost:5173
API_TOKEN=mc_2026_super_seguro_9xK!2
DEFAULT_COUNTRY_CODE=57
WHATSAPP_CLIENT_ID=matucash-main
# Entre un envio y el siguiente (cola global): mas alto = menos riesgo de patron robotico
MIN_SEND_DELAY_MS=8000
MAX_SEND_DELAY_MS=22000
# Pausa antes de empezar a escribir (por mensaje)
PRE_SEND_DELAY_MIN_MS=400
PRE_SEND_DELAY_MAX_MS=2200
# Duracion simulacion "escribiendo..." (se escala por longitud del texto)
TYPING_DURATION_MIN_MS=1200
TYPING_DURATION_MAX_MS=12000
TYPING_BASE_MS=600
TYPING_MS_PER_CHAR=28
TYPING_JITTER_MS=900
SIMULATE_TYPING=true
# Evita duplicados por evento y reduce riesgo de bloqueo
NOTIF_COOLDOWN_LOAN_CREATED_MS=21600000
NOTIF_COOLDOWN_PAYMENT_MS=90000
NOTIF_COOLDOWN_OVERDUE_MS=86400000
# Por seguridad, no enviar imagen de ticket automaticamente
SEND_TICKET_MEDIA=false
HEADLESS=true
TRUST_PROXY=true
# Imágenes (cédula, etc.): carpeta en disco y tamaño máximo por archivo (MB)
UPLOADS_DIR=./uploads
MAX_UPLOAD_MB=6

# Frontend para retorno de checkout
FRONTEND_APP_URL=http://localhost:5173

# Firebase Admin (usa credenciales por defecto O JSON inline)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_FILE=

# Wompi
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_WEBHOOK_SECRET=
WOMPI_BASE_URL=https://production.wompi.co/v1
WOMPI_TEST_BASE_URL=https://sandbox.wompi.co/v1

# Plan único mensual
CASHPRO_MONTHLY_COP=15000

# Backups por correo (Gmail con contraseña de aplicación)
BACKUP_MAILER_HOST=smtp.gmail.com
BACKUP_MAILER_PORT=465
BACKUP_MAILER_SECURE=true
BACKUP_MAILER_USER=matucatalogo@gmail.com
BACKUP_MAILER_PASS=chkecyockdowjycz
BACKUP_MAILER_FROM="MatuCash Backups <matucash.backups@gmail.com>"